# Frontend environment — copy to .env for local dev, .env.production for deployment
# Local dev with Vite: use /api so requests stay on the dev server and proxy to the backend (phone LAN tests).
# Production: full URL to your API.
VITE_API_URL=https://api.permicwear.co.ke/api

# Set to 'demo' to show demo account panel on login screen (development only)
# Set to 'production' to hide demo panel
VITE_MODE=production
